# Copy this to .env and fill with your Supabase project values.
# IMPORTANT: Never commit real credentials. Keep .env in .gitignore.
# 
# Deployment: Set these environment variables on Vercel/Heroku dashboard
# For Supabase details, see: https://app.supabase.com/project/_/settings/api

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_ANON_KEY=your-supabase-anon-key
PORT=3000
